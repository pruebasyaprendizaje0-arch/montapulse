rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: is the user signed in?
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Helper: is the user the Super Admin?
    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.email == "pruebasyaprendizaje0@gmail.com";
    }

    // Helper: does the user have the admin role?
    // Note: This requires getting the user document which costs a read
    function hasAdminRole() {
      return isSignedIn() && get(/databases/$(database)/documents/users_v2/$(request.auth.uid)).data.role == "admin";
    }

    function isAdmin() {
      return isSuperAdmin() || hasAdminRole();
    }

    // Users: Only owner or admin can read/write
    match /users_v2/{userId} {
      allow read: if isSignedIn();
      allow write: if (isSignedIn() && request.auth.uid == userId) || isSuperAdmin();
    }

    // Events: Public read, owner or admin write
    match /events/{eventId} {
      allow read: if true;
      allow create: if isSignedIn() && (request.resource.data.ownerId == request.auth.uid || isAdmin());
      allow update, delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    // Businesses: Public read, owner or admin write
    match /businesses/{bizId} {
      allow read: if true;
      allow create: if isSignedIn(); // Anyone can create a business initially
      allow update, delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    // Favorites: Only owner can manage their favorites
    match /favorites/{favId} {
      allow read: if isSignedIn() && request.auth.uid == resource.data.userId;
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.userId;
      allow delete: if isSignedIn() && request.auth.uid == resource.data.userId;
    }

    // Settings: Public read, Admin only write
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
