rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────────────────────────────
    // HELPERS DE AUTENTICACIÓN
    // ─────────────────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.email == "pruebasyaprendizaje0@gmail.com";
    }

    // NOTA DE COSTO: hasAdminRole() consume 1 lectura por llamada.
    // Se puede eliminar si solo usas isSuperAdmin(). Por ahora solo se llama
    // en paths de escritura para minimizar el impacto.
    function hasAdminRole() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users_v2/$(request.auth.uid)).data.role == "admin";
    }

    function isAdmin() {
      return isSuperAdmin() || hasAdminRole();
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ─────────────────────────────────────────────────────────────────────────
    // HELPERS DE VALIDACIÓN DE TIPOS (Cost-Saving: rechazan antes de procesar)
    // Un bot que envíe 10.000 docs malformados no consume cuota de escritura.
    // ─────────────────────────────────────────────────────────────────────────

    // Valida un string: presente, no vacío, longitud máxima
    function isValidString(val, maxLen) {
      return val is string && val.size() > 0 && val.size() <= maxLen;
    }

    // Valida un string opcional (puede ser null/ausente, pero si existe debe cumplir)
    function isOptionalString(val, maxLen) {
      return val == null || (val is string && val.size() <= maxLen);
    }

    // Valida que un campo sea un número positivo
    function isPositiveNumber(val) {
      return val is number && val >= 0;
    }

    // Valida estructura básica de un evento
    function isValidEvent(data) {
      return isValidString(data.title, 120)
          && isValidString(data.description, 1500)
          && isValidString(data.category, 60)
          && isValidString(data.vibe, 40)
          && isValidString(data.sector, 40)
          && isValidString(data.imageUrl, 500)
          && data.startAt is timestamp
          && data.endAt is timestamp
          && data.endAt > data.startAt
          && isPositiveNumber(data.interestedCount)
          // Protección anti-bot: el documento no puede tener más de 25 campos
          && data.keys().size() <= 25;
    }

    // Valida estructura básica de un negocio/punto de referencia
    function isValidBusiness(data) {
      return isValidString(data.name, 100)
          && isValidString(data.description, 1000)
          && isValidString(data.sector, 40)
          && isValidString(data.category, 60)
          && isOptionalString(data.whatsapp, 30)
          && isOptionalString(data.phone, 25)
          && isOptionalString(data.instagram, 60)
          && isOptionalString(data.email, 100)
          && isOptionalString(data.imageUrl, 500)
          // Protección anti-bot: límite de campos
          && data.keys().size() <= 30;
    }

    // Valida estructura básica de un usuario
    function isValidUser(data) {
      return isValidString(data.name, 60)
          && isValidString(data.email, 100)
          && isOptionalString(data.avatarUrl, 500)
          && isOptionalString(data.locality, 80)
          // Protección: no se puede alterar el rol desde el cliente
          && (!data.keys().hasAll(['role']) || data.role in ['visitor', 'host'])
          && data.keys().size() <= 20;
    }

    // Valida un post de comunidad
    function isValidPost(data) {
      return isValidString(data.content, 800)
          && isOptionalString(data.imageUrl, 500)
          && data.keys().size() <= 15;
    }

    // Valida un mensaje de chat
    function isValidMessage(data) {
      return isValidString(data.text, 600)
          && isOptionalString(data.imageUrl, 500)
          && data.keys().size() <= 12;
    }

    // Valida una reseña
    function isValidReview(data) {
      return isValidString(data.comment, 500)
          && data.rating is number
          && data.rating >= 1
          && data.rating <= 5
          && data.keys().size() <= 12;
    }

    // ─────────────────────────────────────────────────────────────────────────
    // COLECCIÓN: events
    // ─────────────────────────────────────────────────────────────────────────
    match /events/{eventId} {
      // Lectura pública — no requiere auth (eventos son públicos)
      allow read: if true;

      // Creación: usuario autenticado + datos válidos + es el dueño o admin
      allow create: if isSignedIn()
          && isValidEvent(request.resource.data)
          && (request.resource.data.ownerId == request.auth.uid || isAdmin());

      // Actualización:
      // - El dueño puede hacer cualquier update
      // - Cualquier usuario autenticado puede incrementar el interestedCount
      allow update: if isSignedIn() && (
        resource.data.ownerId == request.auth.uid || 
        isAdmin() ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['interestedCount']))
      );

      // Borrado: solo dueño o admin
      allow delete: if isSignedIn()
          && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    // ─────────────────────────────────────────────────────────────────────────
    // COLECCIÓN: businesses
    // ─────────────────────────────────────────────────────────────────────────
    match /businesses/{bizId} {
      allow read: if true;

      allow create: if isSignedIn()
          && isValidBusiness(request.resource.data);

      // Updates:
      // - El dueño puede hacer cualquier update
      // - Usuarios pueden actualizar métricas (viewCount, followerCount, reviewCount, rating)
      allow update: if isSignedIn() && (
        resource.data.ownerId == request.auth.uid || 
        isAdmin() ||
        (request.resource.data.diff(resource.data).affectedKeys().hasAll(['viewCount']) && request.resource.data.diff(resource.data).affectedKeys().size() == 1) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followerCount', 'reviewCount', 'rating']))
      );

      allow delete: if isSignedIn()
          && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    // ─────────────────────────────────────────────────────────────────────────
    // COLECCIÓN: users_v2
    // ─────────────────────────────────────────────────────────────────────────
    match /users_v2/{userId} {
      // Lectura: el propio usuario o admin
      allow read: if isOwner(userId) || isAdmin();

      // Escritura: solo el propio usuario con datos válidos, o admin
      allow write: if (isOwner(userId) && isValidUser(request.resource.data))
          || isSuperAdmin();
    }

    // ─────────────────────────────────────────────────────────────────────────
    // COLECCIÓN: favorites
    // ─────────────────────────────────────────────────────────────────────────
    match /favorites/{favId} {
      allow read: if isSignedIn() && request.auth.uid == resource.data.userId;

      allow create: if isSignedIn()
          && request.auth.uid == request.resource.data.userId
          && request.resource.data.keys().hasAll(['userId', 'eventId'])
          && request.resource.data.keys().size() <= 5;

      allow delete: if isSignedIn() && request.auth.uid == resource.data.userId;
    }

    // ─────────────────────────────────────────────────────────────────────────
    // COLECCIÓN: rsvps
    // ─────────────────────────────────────────────────────────────────────────
    match /rsvps/{rsvpId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
          && request.auth.uid == request.resource.data.userId
          && request.resource.data.keys().hasAll(['userId', 'eventId'])
          && request.resource.data.keys().size() <= 5;

      allow delete: if isSignedIn() && request.auth.uid == resource.data.userId;
    }

    // ─────────────────────────────────────────────────────────────────────────
    // COLECCIÓN: follows
    // ─────────────────────────────────────────────────────────────────────────
    match /follows/{followId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
          && request.auth.uid == request.resource.data.userId
          && request.resource.data.keys().hasAll(['userId', 'businessId'])
          && request.resource.data.keys().size() <= 5;

      allow delete: if isSignedIn() && request.auth.uid == resource.data.userId;
    }

    // ─────────────────────────────────────────────────────────────────────────
    // COLECCIÓN: posts (comunidad)
    // ─────────────────────────────────────────────────────────────────────────
    match /posts/{postId} {
      allow read: if true;

      allow create: if isSignedIn()
          && isValidPost(request.resource.data)
          && request.resource.data.authorId == request.auth.uid;

      // Solo likes/comments se pueden actualizar, no el contenido por otros
      allow update: if isSignedIn()
          && (resource.data.authorId == request.auth.uid || isAdmin());

      allow delete: if isSignedIn()
          && (resource.data.authorId == request.auth.uid || isAdmin());
    }

    // ─────────────────────────────────────────────────────────────────────────
    // COLECCIÓN: messages (chat global)
    // ─────────────────────────────────────────────────────────────────────────
    match /messages/{msgId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
          && isValidMessage(request.resource.data)
          && request.resource.data.senderId == request.auth.uid;

      // El remitente puede borrar su propio mensaje
      allow delete: if isAdmin()
          || (isSignedIn() && resource.data.senderId == request.auth.uid);
    }

    // ─────────────────────────────────────────────────────────────────────────
    // COLECCIÓN: chatRooms + mensajes
    // Solo participantes pueden leer, escribir o borrar mensajes.
    // Los negocios Premium pueden crear grupos (create sin restricción de plan
    // porque la restricción ya está en el cliente; en rules no tenemos el plan).
    // ─────────────────────────────────────────────────────────────────────────

    // Helper: el usuario autenticado es participante del room actual
    function isRoomParticipant(roomId) {
      return get(/databases/$(database)/documents/chatRooms/$(roomId)).data.participants.hasAny([request.auth.uid]);
    }

    match /chatRooms/{roomId} {
      // Solo participantes pueden leer el room
      allow read: if isSignedIn()
          && resource.data.participants.hasAny([request.auth.uid]);

      // Cualquier usuario autenticado puede crear un room (es el primer mensaje)
      allow create: if isSignedIn()
          && request.resource.data.keys().hasAll(['name', 'type', 'participants'])
          && request.resource.data.participants is list
          && request.auth.uid in request.resource.data.participants
          && request.resource.data.participants.size() >= 2
          && request.resource.data.participants.size() <= 50;

      allow update: if isSignedIn()
          && resource.data.participants.hasAny([request.auth.uid]);
      allow delete: if isAdmin();

      match /messages/{msgId} {
        // Solo participantes del room pueden leer mensajes
        allow read: if isSignedIn() && isRoomParticipant(roomId);

        // Solo participantes pueden escribir mensajes
        allow create: if isSignedIn()
            && isRoomParticipant(roomId)
            && isValidMessage(request.resource.data)
            && (request.resource.data.senderId == request.auth.uid
                || request.resource.data.isBusinessMessage == true);

        // El remitente puede borrar su propio mensaje; participantes pueden borrar para auto-clean
        allow delete: if isSignedIn()
            && (resource.data.senderId == request.auth.uid || isRoomParticipant(roomId));
      }
    }

    // ─────────────────────────────────────────────────────────────────────────
    // COLECCIÓN: businessReviews
    // ─────────────────────────────────────────────────────────────────────────
    match /businessReviews/{reviewId} {
      allow read: if true;

      allow create: if isSignedIn()
          && isValidReview(request.resource.data)
          && request.resource.data.userId == request.auth.uid;

      allow update, delete: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────────────────────
    // COLECCIÓN: settings (configuración global de la app)
    // ─────────────────────────────────────────────────────────────────────────
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────────────────────
    // COLECCIÓN: customLocalities
    // ─────────────────────────────────────────────────────────────────────────
    match /customLocalities/{localityId} {
      allow read: if true;
      allow create: if isAdmin()
          && isValidString(request.resource.data.name, 60)
          && request.resource.data.keys().size() <= 8;
      allow delete: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────────────────────
    // DENY-ALL por defecto (catch-all)
    // No uses isAdmin() aquí — evita el costo de la lectura extra innecesaria
    // ─────────────────────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
