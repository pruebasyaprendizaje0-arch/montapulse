rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ========== FUNCIONES HELPER ==========
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users_v2/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.admin == true || 
        (exists(/databases/$(database)/documents/users_v2/$(request.auth.uid)) && getUserData().role == 'admin') ||
        (request.auth.token.email.lower() == 'pruebasyaprendizaje0@gmail.com' ||
         request.auth.token.email.lower() == 'fhernandezcalle@gmail.com' ||
         request.auth.token.email.lower() == 'ubicameinformacion@gmail.com')
      );
    }

    function isSuperAdminEmail() {
      return isAuthenticated() && (
        request.auth.token.email.lower() == 'pruebasyaprendizaje0@gmail.com' ||
        request.auth.token.email.lower() == 'fhernandezcalle@gmail.com' ||
        request.auth.token.email.lower() == 'ubicameinformacion@gmail.com'
      );
    }

    // ========== REGLAS DE COLECCIONES ==========

    // Users V2: Público para perfiles, pero solo dueño/admin escribe
    match /users_v2/{userId} {
      allow read: if true;
      allow create: if isOwner(userId) && (
        isSuperAdminEmail() ||
        (
          (!request.resource.data.keys().hasAny(['role']) || request.resource.data.role == 'visitor' || request.resource.data.role == 'host') &&
          (!request.resource.data.keys().hasAny(['plan']) || request.resource.data.plan == 'Free')
        )
      );
      allow update: if isAdmin() || isSuperAdminEmail() || (
        isOwner(userId) && 
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'plan'])
      );
      allow delete: if isAdmin() || isSuperAdminEmail();
    }
    
    // Negocios: Público read, incrementos de vista permitidos para todos
    match /businesses/{businessId} {
      allow read: if true;
      allow create: if isAuthenticated() && 
                    request.resource.data.ownerId == request.auth.uid &&
                    request.resource.data.keys().hasAll(['name', 'category']) &&
                    request.resource.data.name is string;
      allow update: if 
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount', 'monthlyViews', 'lastMonthlyResetDate'])) ||
        (isAuthenticated() && (resource.data.ownerId == request.auth.uid || isAdmin()));
      allow delete: if isAdmin();
    }
    
    // Eventos: Público read, incrementos de vista/click permitidos para todos
    match /events/{eventId} {
      allow read: if true;
      allow create: if isAuthenticated() && 
                    request.resource.data.ownerId == request.auth.uid &&
                    request.resource.data.keys().hasAll(['title', 'date']) &&
                    request.resource.data.title is string;
      allow update: if 
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['interestedCount', 'viewCount', 'clickCount', 'monthlyViews'])) ||
        (isAuthenticated() && (resource.data.ownerId == request.auth.uid || isAdmin()));
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.ownerId == request.auth.uid);
    }
    
    // Comunidad: Público read, creación auth
    match /posts/{postId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.authorId == request.auth.uid;
      allow update: if 
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'commentCount', 'likesCount', 'commentsCount'])) ||
        (isAuthenticated() && (resource.data.authorId == request.auth.uid || isAdmin()));
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.authorId == request.auth.uid);
    }

    // Anuncios: Público read
    match /announcements/{announcementId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.senderId == request.auth.uid;
      allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.senderId == request.auth.uid);
    }

    // RSVPs: Público read para conteos, Auth write
    match /rsvps/{rsvpId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Chat Global (Pulso Global): Público read
    match /pulso_global/{msgId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Chat Privado: Solo participantes o admin
    match /chatRooms/{roomId} {
      allow read: if isAuthenticated() && (request.auth.uid in resource.data.participants || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participants;
      allow update: if isAuthenticated() && (request.auth.uid in resource.data.participants || isAdmin());
      
      match /messages/{messageId} {
        allow read: if isAuthenticated() && (get(/databases/$(database)/documents/chatRooms/$(roomId)).data.participants.hasAny([request.auth.uid]) || isAdmin());
        allow create: if isAuthenticated() && request.resource.data.senderId == request.auth.uid;
        allow delete: if isAdmin() || (isAuthenticated() && resource.data.senderId == request.auth.uid);
      }
    }

    // Reseñas: Público read
    match /businessReviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }

    // Localidades: Público read
    match /customLocalities/{localityId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Seguidores: Público read
    match /follows/{followId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Favoritos: Privado
    match /favorites/{favId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Notificaciones: Privado
    match /notifications/{notifId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated(); // Allowed for system/other users to notify
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }

    // Puntos y Vales: Privado
    match /points/{pointId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }
    match /vouchers/{voucherId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Ajustes: Público read
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
      allow update: if settingId == 'visits' && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['count']);
    }

    // Cupones: Público read, owner/admin manage
    match /coupons/{couponId} {
      allow read: if true;
      allow create: if isAuthenticated() && (request.resource.data.ownerId == request.auth.uid || isAdmin());
      allow update: if isAuthenticated() && (
        // Allow incrementing currentUses for redemption
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['currentUses', 'updatedAt'])) ||
        resource.data.ownerId == request.auth.uid || 
        isAdmin()
      );
      allow delete: if isAuthenticated() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    // Redenciones de cupones: Auth read/create, owner/admin manage
    match /couponRedemptions/{redemptionId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || 
        resource.data.ownerId == request.auth.uid || 
        isAdmin()
      );
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.ownerId == request.auth.uid || 
        isAdmin()
      );
      allow delete: if isAdmin();
    }
    
    // Boosts: Privado read/create
    match /boosts/{boostId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }
    
    // Booking Addons
    match /booking_addons/{businessId} {
      allow read: if true;
      allow write: if isAdmin() || (
        isAuthenticated() && 
        get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId == request.auth.uid
      );
    }

    // Booking Configs
    match /booking_configs/{businessId} {
      allow read: if true;
      allow write: if isAdmin() || (
        isAuthenticated() && 
        get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId == request.auth.uid
      );
    }

    // Booking Inventories
    match /room_inventories/{itemId} {
      allow read: if true;
      allow write: if isAdmin() || (
        isAuthenticated() && 
        (
          (request.resource != null && get(/databases/$(database)/documents/businesses/$(request.resource.data.businessId)).data.ownerId == request.auth.uid) ||
          (resource != null && get(/databases/$(database)/documents/businesses/$(resource.data.businessId)).data.ownerId == request.auth.uid)
        )
      );
    }
    match /table_inventories/{itemId} {
      allow read: if true;
      allow write: if isAdmin() || (
        isAuthenticated() && 
        (
          (request.resource != null && get(/databases/$(database)/documents/businesses/$(request.resource.data.businessId)).data.ownerId == request.auth.uid) ||
          (resource != null && get(/databases/$(database)/documents/businesses/$(resource.data.businessId)).data.ownerId == request.auth.uid)
        )
      );
    }
    match /slot_inventories/{itemId} {
      allow read: if true;
      allow write: if isAdmin() || (
        isAuthenticated() && 
        (
          (request.resource != null && get(/databases/$(database)/documents/businesses/$(request.resource.data.businessId)).data.ownerId == request.auth.uid) ||
          (resource != null && get(/databases/$(database)/documents/businesses/$(resource.data.businessId)).data.ownerId == request.auth.uid)
        )
      );
    }

    // Bookings
    match /bookings/{bookingId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin() || (
        isAuthenticated() && 
        (
          (request.resource != null && get(/databases/$(database)/documents/businesses/$(request.resource.data.businessId)).data.ownerId == request.auth.uid) ||
          (resource != null && get(/databases/$(database)/documents/businesses/$(resource.data.businessId)).data.ownerId == request.auth.uid)
        )
      );
    }

    // Default: Solo Admin
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}