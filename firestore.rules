rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null && 
        (get(/databases/$(database)/documents/users_v2/$(request.auth.uid)).data.role == 'admin' || 
         request.auth.token.admin == true);
    }

    // Helper to check ownership
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    match /users_v2/{userId} {
      // Admins can do anything. Users can read/write their own profile.
      // Allow 'get' for public profile viewing (limited fields should be handled by app logic, 
      // but Firestore rules can only restrict the whole doc or specific fields via 'list')
      allow read: if true; 
      allow write: if isAdmin() || isOwner(userId);
    }

    match /businesses/{businessId} {
      allow read: if true;
      // Only admins or the owner of the business can write
      allow write: if isAdmin() || 
        (request.auth != null && request.auth.uid == resource.data.ownerId) ||
        (request.auth != null && !exists(/databases/$(database)/documents/businesses/$(businessId))); // Allow creation
    }

    match /events/{eventId} {
      allow read: if true;
      // Only admins or the host who created the event can write
      allow write: if isAdmin() || 
        (request.auth != null && (get(/databases/$(database)/documents/users_v2/$(request.auth.uid)).data.role == 'host' || isAdmin()));
    }

    match /follows/{followId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    match /favorites/{favId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow write: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }

    match /rsvps/{rsvpId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }

    match /businessReviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if isAdmin() || (request.auth != null && request.auth.uid == resource.data.userId);
    }

    match /app_settings/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /chat_rooms/{roomId} {
      allow read, write: if request.auth != null && (request.auth.uid in resource.data.participants || isAdmin());
      allow create: if request.auth != null;
    }

    match /messages/{messageId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
    }

    // Comprehensive fallback for any other collections - DENY by default for safety
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
