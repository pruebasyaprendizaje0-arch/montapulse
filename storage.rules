rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.admin == true || 
        request.auth.token.expert == true
      );
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isValidImage() {
      return request.resource.contentType.matches('image/(jpeg|png|gif|webp)') 
        && request.resource.size <= 5 * 1024 * 1024;
    }
    
    function isValidVideo() {
      return request.resource.contentType.matches('video/(mp4|webm)') 
        && request.resource.size <= 100 * 1024 * 1024;
    }

    function isValidMedia() {
      return isValidImage() || isValidVideo();
    }
    
    // Eventos - Acceso público lectura, Admin o Auth escritura
    match /events/{eventId}/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() || (isAuthenticated() && isValidMedia());
    }
    
    // Negocios
    match /businesses/{businessId}/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() || (isAuthenticated() && isValidMedia());
    }
    
    // Usuarios (Avatares)
    match /users/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() || (isOwner(userId) && isValidImage());
    }
    
    // Chat y Carpeta General de Uploads
    match /chat/{roomId}/{allPaths=**} {
      allow read: if isAuthenticated() || isAdmin();
      allow write: if isAuthenticated() && isValidMedia();
    }
    
    match /uploads/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() || (isOwner(userId) && isValidMedia());
    }
    
    // Anuncios
    match /announcements/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() || (isAuthenticated() && isValidImage());
    }

    // Default - Solo Admin puede manejar archivos fuera de las rutas anteriores
    match /{allPaths=**} {
      allow read, write: if isAdmin();
    }
  }
}